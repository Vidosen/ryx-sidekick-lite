<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:appui="Unity.AppUI.UI" editor-extension-mode="True">
    <!-- APPUI-T01-04: Smoke template verifying App UI UXML namespace in the Sidekick package.
